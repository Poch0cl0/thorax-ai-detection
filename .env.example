# Copiar a .env y ajustar. Nunca commitear .env con secretos reales.

# --- Backend ---
DATABASE_URL=sqlite:///./thorax.db
# En Docker compose se usa PostgreSQL; URL de ejemplo:
# DATABASE_URL=postgresql+psycopg2://thorax:thorax@localhost:5432/thorax

SECRET_KEY=genera-una-clave-larga-aleatoria
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Orígenes CORS separados por coma (URL del frontend en desarrollo)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Modelo de IA (opcional; vacío = inferencia simulada)
MODEL_PATH=
MODEL_VERSION=stub-0.1.0
INFERENCE_TIMEOUT_SECONDS=120

ENVIRONMENT=development

# --- Frontend (Vite; solo en build) ---
# Vacío en producción con nginx haciendo proxy a /api
# VITE_API_BASE_URL=http://127.0.0.1:8000

# --- Docker compose (opcional) ---
# SECRET_KEY=
# MODEL_PATH=
