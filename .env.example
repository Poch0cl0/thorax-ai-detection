# Copiar a .env y ajustar. Nunca commitear .env con secretos reales.

# --- Backend ---
DATABASE_URL=sqlite:///./thorax.db
# En Docker Compose se usa PostgreSQL; URL de ejemplo:
# DATABASE_URL=postgresql+psycopg2://thorax:thorax@localhost:5432/thorax

SECRET_KEY=genera-una-clave-larga-aleatoria
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Orígenes CORS separados por coma (URL del frontend en desarrollo)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Versión del modelo (informativo)
MODEL_VERSION=sklearn-1.0.0

# Timeout de inferencia en segundos (reducido al eliminar Spark)
INFERENCE_TIMEOUT_SECONDS=30

# Rutas a los modelos scikit-learn exportados como .joblib
# Exportar desde Google Colab con: joblib.dump(modelo, 'modelo_lr.joblib')
# Si los archivos no existen, el sistema opera en modo stub (sin inferencia real)
LR_MODEL_PATH=models/modelo_lr.joblib
RF_MODEL_PATH=models/modelo_rf.joblib

# Preprocesamiento de imagen
IMAGE_SIZE=64
MAX_IMAGE_SIZE_MB=10

ENVIRONMENT=development

# --- Frontend (Vite; solo en build) ---
# Vacío en producción con nginx haciendo proxy a /api
# VITE_API_BASE_URL=http://127.0.0.1:8000
